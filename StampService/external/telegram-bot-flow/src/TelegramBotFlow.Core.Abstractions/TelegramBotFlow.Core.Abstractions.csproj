<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>TelegramBotFlow.Core.Abstractions</PackageId>
    <Version>1.0.0</Version>
    <Authors>SachkovTech</Authors>
    <Description>Контракты и интерфейсы фреймворка TelegramBotFlow — нижний слой, без зависимостей на реализацию</Description>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <!-- Разрешаем доступ к internal-членам для реализаций фреймворка и тестов -->
  <ItemGroup>
    <InternalsVisibleTo Include="TelegramBotFlow.Core" />
    <InternalsVisibleTo Include="TelegramBotFlow.Core.Redis" />
    <InternalsVisibleTo Include="TelegramBotFlow.Core.Tests" />
    <InternalsVisibleTo Include="TelegramBotFlow.IntegrationTests" />
  </ItemGroup>

  <ItemGroup>
    <!-- Только абстракции DI — не полный Microsoft.Extensions.DependencyInjection -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Telegram.Bot" />
  </ItemGroup>

</Project>
