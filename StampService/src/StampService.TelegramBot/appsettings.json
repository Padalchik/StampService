{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "Telegram.Bot": "Information",
        "TelegramBotFlow": "Information"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "StampService.TelegramBot"
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5441"
        }
      }
    ]
  },
  "Bot": {
    "Mode": "POLLING"
  },
  "Telegram": {
    "BotToken": "",
    "BotUsername": ""
  },
  "StartupNotifications": {
    "Enabled": true,
    "WebInterfaceUrl": "http://localhost:5173/login",
    "SeqUrl": "http://localhost:5441"
  },
  "Admin": {
    "TelegramUserIds": [
      278225388
    ]
  }
}
